{
  "name": "@checkoutwatch/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "clean": "node -e \"require('fs').rmSync('build',{recursive:true,force:true})\"",
    "dev": "react-router dev --host 0.0.0.0 --port 3000",
    "start": "react-router-serve ./build/server/index.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@checkoutwatch/alerts": "workspace:*",
    "@checkoutwatch/core": "workspace:*",
    "@checkoutwatch/db": "workspace:*",
    "@checkoutwatch/engine": "workspace:*",
    "@checkoutwatch/queue": "workspace:*",
    "@checkoutwatch/shopify": "workspace:*",
    "@checkoutwatch/worker": "workspace:*",
    "@prisma/client": "6.19.0",
    "@react-router/node": "7.18.1",
    "@react-router/serve": "7.18.1",
    "@shopify/polaris": "13.9.5",
    "@shopify/shopify-app-react-router": "1.2.1",
    "@shopify/shopify-app-session-storage-prisma": "9.0.1",
    "chromium-bidi": "0.6.0",
    "isbot": "5.1.30",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router": "7.18.1"
  },
  "devDependencies": {
    "@react-router/dev": "7.18.1",
    "@types/react": "18.3.23",
    "@types/react-dom": "18.3.7",
    "vite": "7.0.6"
  }
}
