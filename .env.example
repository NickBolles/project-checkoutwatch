# CheckoutWatch local defaults require no credentials. Copy to .env only to override them.

# Production database (required in production). Local default: SQLite at file:./var/dev.db.
# DATABASE_URL=postgresql://user:password@host:5432/checkoutwatch
DATABASE_URL=file:./var/dev.db

# Production queue (required in production). Without REDIS_URL the in-process memory driver is used.
# REDIS_URL=redis://localhost:6379
QUEUE_DRIVER=memory

# Shopify Partner credentials (all four are required when SHOPIFY_AUTH=real).
# SHOPIFY_API_KEY=
# SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=http://localhost:3000
SHOPIFY_SCOPES=read_products,read_themes
SHOPIFY_AUTH=mock
# Optional override for locally signed Shopify webhook tests.
SHOPIFY_MOCK_WEBHOOK_SECRET=checkoutwatch-local-webhook-secret

# Optional AI diagnosis. Without a key, the deterministic heuristic diagnoser is used.
# ANTHROPIC_API_KEY=
LLM_MODEL=claude-opus-4-8
DIAGNOSIS_PROVIDER=heuristic

# Alert providers (required only when ALERT_TRANSPORT=real). Mock writes later go to var/outbox/.
# RESEND_API_KEY=
# RESEND_WEBHOOK_SECRET=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=+15555550123
ALERT_TRANSPORT=mock

# Local artifact storage requires no credentials.
ARTIFACT_STORE=local
ARTIFACT_DIR=var/artifacts

# Production: set a base64-encoded 32-byte key. Development auto-generates this into .env.
# ENCRYPTION_KEY=

ENGINE_CONCURRENCY=2
RECHECK_DELAY_SECONDS=90
REOPEN_COOLDOWN_MINUTES=30
PRODUCT_UNAVAILABLE_AUTOPAUSE=6
INLINE_WORKER=1
FIXTURE_STOREFRONT_URL=http://localhost:4600
CONTROL_PROBE_URL=http://localhost:4602/health
KNOWN_PAYMENT_ORIGINS=https://checkout.shopifycs.com,https://js.stripe.com,http://localhost:4601
