{
  "name": "@checkoutwatch/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "db:generate": "node scripts/prisma.mjs generate",
    "db:migrate": "node scripts/prisma.mjs migrate dev --name init",
    "db:push": "node scripts/prisma.mjs db push",
    "db:seed": "tsx src/seed.ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@checkoutwatch/alerts": "workspace:*",
    "@checkoutwatch/core": "workspace:*",
    "@prisma/client": "6.19.0",
    "zod": "3.25.67"
  },
  "devDependencies": {
    "prisma": "6.19.0"
  }
}
