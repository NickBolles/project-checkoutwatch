# Copy to .env.production on the VPS, chmod 600, and replace every placeholder.
# Never commit .env.production. Back up ENCRYPTION_KEY in the password manager.

NODE_ENV=production
PUBLIC_HOST=checkoutwatch.nickbolles.com
TRAEFIK_NETWORK=traefik
TRAEFIK_CERTRESOLVER=letsencrypt

# Fresh, private Postgres volume. Generate a long random password.
POSTGRES_DB=checkoutwatch
POSTGRES_USER=checkoutwatch
POSTGRES_PASSWORD=REPLACE_WITH_A_LONG_RANDOM_PASSWORD
DATABASE_URL=postgresql://checkoutwatch:REPLACE_WITH_A_LONG_RANDOM_PASSWORD@postgres:5432/checkoutwatch

REDIS_URL=redis://redis:6379
QUEUE_DRIVER=bullmq
# Must be identical for web and every worker replica. Do not include a PID or hostname.
QUEUE_PREFIX=checkoutwatch
INLINE_WORKER=0
WORKER_HEALTH_PORT=3001
ENGINE_CONCURRENCY=1

SHOPIFY_AUTH=real
SHOPIFY_API_KEY=REPLACE_WITH_PARTNER_APP_CLIENT_ID
SHOPIFY_API_SECRET=REPLACE_WITH_PARTNER_APP_CLIENT_SECRET
SHOPIFY_APP_URL=https://checkoutwatch.nickbolles.com
SHOPIFY_SCOPES=read_products,read_themes
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=REPLACE_WITH_BASE64_32_BYTE_KEY

# Required: a separately hosted known-good HTTPS health endpoint. It must not resolve to this VPS.
CONTROL_PROBE_URL=https://REPLACE_WITH_INDEPENDENT_PROBE_HOST/health

ALERT_TRANSPORT=real
RESEND_API_KEY=REPLACE_WITH_RESEND_API_KEY
RESEND_WEBHOOK_SECRET=REPLACE_WITH_RESEND_WEBHOOK_SECRET
# Optional: configure only after Twilio sender/A2P work is complete.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# Optional: absent credentials retain the deterministic heuristic diagnosis.
DIAGNOSIS_PROVIDER=heuristic
LLM_MODEL=claude-opus-4-8
# ANTHROPIC_API_KEY=

ARTIFACT_STORE=local
ARTIFACT_DIR=/app/var/artifacts
KNOWN_PAYMENT_ORIGINS=https://checkout.shopifycs.com,https://js.stripe.com
RECHECK_DELAY_SECONDS=90
REOPEN_COOLDOWN_MINUTES=30
PRODUCT_UNAVAILABLE_AUTOPAUSE=6
